{
  "version": 2,
  "builds": [
    {
      "src": "api/*.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["content/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/mcp",
      "dest": "/api/mcp.ts"
    },
    {
      "src": "/health",
      "dest": "/api/health.ts"
    }
  ]
}
