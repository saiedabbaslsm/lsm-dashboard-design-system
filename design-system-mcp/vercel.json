{
  "rewrites": [
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/health", "destination": "/api/health" }
  ],
  "functions": {
    "api/mcp.ts": {
      "includeFiles": "content/**",
      "maxDuration": 300
    },
    "api/health.ts": {
      "includeFiles": "content/**"
    }
  }
}

